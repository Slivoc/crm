@rfqs_bp.route('/create_top_level_requisition', methods=['POST'])
def create_top_level_requisition():
    try:
        db = get_db_connection()
        cursor = db.cursor()

        # Generate a unique reference for the top-level requisition
        reference = f"TLR-{datetime.now().strftime('%Y%m%d%H%M%S')}"
        created_at = datetime.now().strftime('%Y-%m-%d %H:%M:%S')

        cursor.execute('''
            INSERT INTO top_level_requisitions (reference, created_at)
            VALUES (?, ?)
        ''', (reference, created_at))

        top_level_requisition_id = cursor.lastrowid

        db.commit()
        cursor.close()
        db.close()

        return jsonify({'success': True, 'top_level_requisition_id': top_level_requisition_id, 'reference': reference})
    except Exception as e:
        print(f"Error in create_top_level_requisition: {str(e)}")
        return jsonify({'success': False, 'error': str(e)})

def add_requisition_to_top_level(top_level_requisition_id, requisition_id, max_retries=5, delay=0.1):
    db = get_db_connection()
    for attempt in range(max_retries):
        try:
            cursor = db.cursor()
            cursor.execute('''
                INSERT INTO requisition_references (top_level_requisition_id, requisition_id)
                VALUES (?, ?)
            ''', (top_level_requisition_id, requisition_id))
            db.commit()
            cursor.close()
            return
        except sqlite3.OperationalError as e:
            if 'database is locked' in str(e) and attempt < max_retries - 1:
                time.sleep(delay)
                delay *= 2  # Exponential backoff
            else:
                raise
        finally:
            db.close()
    raise sqlite3.OperationalError("Database locked after maximum retries")

@rfqs_bp.route('/create_top_level_requisition', methods=['POST'])
def create_top_level_requisition_route():
    try:
        top_level_requisition_id, reference = create_top_level_requisition()
        return jsonify({
            'success': True,
            'top_level_requisition_id': top_level_requisition_id,
            'reference': reference
        })
    except Exception as e:
        print(f"Error in create_top_level_requisition: {str(e)}")  # Add this debug print
        return jsonify({'success': False, 'error': str(e)})


@rfqs_bp.route('/generate_bulk_requisitions', methods=['POST'])
def generate_bulk_requisitions():
    data = request.json
    supplier_id = data.get('supplier_id')
    line_ids = data.get('rfq_lines')
    top_level_requisition_id = data.get('top_level_requisition_id')

    # Assuming status_id 2 represents "sent to supplier"
    SENT_TO_SUPPLIER_STATUS_ID = 2

    try:
        db = get_db_connection()
        cursor = db.cursor()
        cursor.execute('BEGIN TRANSACTION')

        for line_id in line_ids:
            line = get_rfq_line_by_id(line_id)
            rfq_id = line['rfq_id']  # Get rfq_id for each line

            cursor.execute('''
                INSERT INTO requisitions (rfq_id, supplier_id, date, base_part_number, quantity, rfq_line_id)
                VALUES (?, ?, ?, ?, ?, ?)
            ''', (rfq_id, supplier_id, datetime.now().strftime('%Y-%m-%d'), line['base_part_number'],
                  line['quantity'], line_id))
            requisition_id = cursor.lastrowid

            # Update RFQ line status to "sent to supplier"
            cursor.execute('''
                UPDATE rfq_lines
                SET status_id = ?
                WHERE id = ?
            ''', (SENT_TO_SUPPLIER_STATUS_ID, line_id))

            if top_level_requisition_id:
                cursor.execute('''
                    INSERT INTO requisition_references (top_level_requisition_id, requisition_id)
                    VALUES (?, ?)
                ''', (top_level_requisition_id, requisition_id))

        cursor.execute('COMMIT')
        cursor.close()

        return jsonify({'success': True})
    except Exception as e:
        cursor.execute('ROLLBACK')
        print(f"Error in generate_bulk_requisitions: {str(e)}")
        return jsonify({'success': False, 'error': str(e)})
    finally:
        db.close()


@rfqs_bp.route('/get_requisition_details', methods=['GET'])
def get_requisition_details():
    top_level_requisition_id = request.args.get('top_level_requisition_id')
    supplier_id = request.args.get('supplier_id')

    try:
        db = get_db_connection()
        cursor = db.cursor()
        cursor.execute('''
            SELECT r.id, s.name as supplier_name, s.contact_name, s.contact_email,
                   group_concat(DISTINCT rl.base_part_number) as part_numbers, 
                   group_concat(rl.quantity) as quantities
            FROM requisitions r
            JOIN suppliers s ON r.supplier_id = s.id
            JOIN rfq_lines rl ON r.rfq_line_id = rl.id
            JOIN requisition_references rr ON r.id = rr.requisition_id
            WHERE rr.top_level_requisition_id = ? AND r.supplier_id = ?
            GROUP BY rr.top_level_requisition_id, s.name
        ''', (top_level_requisition_id, supplier_id))
        result = cursor.fetchone()
        cursor.close()
        db.close()

        if result:
            part_numbers = result['part_numbers'].split(',') if result['part_numbers'] else []
            quantities = result['quantities'].split(',') if result['quantities'] else []
            return jsonify({
                'success': True,
                'top_level_requisition_id': top_level_requisition_id,
                'supplier_name': result['supplier_name'],
                'contact_name': result['contact_name'],
                'contact_email': result['contact_email'],
                'part_numbers': part_numbers,
                'quantities': quantities
            })
        else:
            return jsonify({'success': False, 'error': 'Requisition details not found'})

    except Exception as e:
        print(f"Error in get_requisition_details: {str(e)}")
        return jsonify({'success': False, 'error': str(e)})


@rfqs_bp.route('/<int:rfq_id>/generate_requisitions_ajax', methods=['POST'])
def generate_requisitions_ajax(rfq_id):
    max_retries = 5
    delay = 0.1

    for attempt in range(max_retries):
        try:
            db = get_db_connection()
            cursor = db.cursor()
            cursor.execute('BEGIN TRANSACTION')

            # Create a top-level requisition
            top_level_reference = f"TLR-{rfq_id}-{datetime.now().strftime('%Y%m%d%H%M%S')}"
            created_at = datetime.now().strftime('%Y-%m-%d %H:%M:%S')
            cursor.execute('''
                INSERT INTO top_level_requisitions (created_at)
                VALUES (?)
            ''', (created_at,))
            top_level_requisition_id = cursor.lastrowid

            rfq_lines = get_rfq_lines(rfq_id)
            suppliers = get_suppliers()
            supplier_emails = {}

            for line in rfq_lines:
                suggested_suppliers = line['suggested_suppliers'].split(',') if line['suggested_suppliers'] else []
                base_part_number = line['base_part_number']  # Keep using base_part_number for database operations
                part_number = line['part_number']  # Retrieve part_number for display purposes

                # Use a set to keep track of suppliers that have already been processed for this line
                processed_suppliers = set()

                for supplier_id in suggested_suppliers:
                    supplier_id = int(supplier_id)

                    # Skip if this supplier has already been processed for this line
                    if supplier_id in processed_suppliers:
                        continue

                    # Mark this supplier as processed
                    processed_suppliers.add(supplier_id)

                    cursor.execute('''
                        INSERT INTO requisitions (rfq_id, supplier_id, date, base_part_number, quantity, rfq_line_id)
                        VALUES (?, ?, ?, ?, ?, ?)
                    ''', (
                        rfq_id,
                        supplier_id,
                        datetime.now().strftime('%Y-%m-%d'),
                        base_part_number,  # Insert base_part_number into the requisitions table
                        line['quantity'],
                        line['id']
                    ))
                    requisition_id = cursor.lastrowid

                    # Link the requisition to the top-level requisition
                    cursor.execute('''
                        INSERT INTO requisition_references (top_level_requisition_id, requisition_id)
                        VALUES (?, ?)
                    ''', (top_level_requisition_id, requisition_id))

                    # Update the rfq_line status to 2 (or whichever status ID is appropriate)
                    cursor.execute('''
                        UPDATE rfq_lines
                        SET status_id = 2
                        WHERE id = ?
                    ''', (line['id'],))

                    # Prepare supplier emails data
                    supplier = next((s for s in suppliers if s['id'] == supplier_id), None)
                    if supplier:
                        if supplier['name'] not in supplier_emails:
                            supplier_emails[supplier['name']] = {
                                'contact_name': supplier['contact_name'],
                                'contact_email': supplier['contact_email'],
                                'lines': []
                            }
                        supplier_emails[supplier['name']]['lines'].append({
                            'part_number': part_number,  # Use part_number for display in emails
                            'quantity': line['quantity']
                        })


            # Update the RFQ status to "Sent to Sourcing"
            status_sent_to_sourcing = "sent to sourcing"
            cursor.execute('UPDATE rfqs SET status = ? WHERE id = ?', (status_sent_to_sourcing, rfq_id))

            cursor.execute('COMMIT')
            db.commit()
            cursor.close()
            db.close()

            return jsonify({
                'success': True,
                'message': 'Requisitions generated successfully and RFQ status updated to Sent to Sourcing!',
                'supplier_emails': supplier_emails,
                'top_level_reference': top_level_reference
            })

        except sqlite3.OperationalError as e:
            if 'database is locked' in str(e) and attempt < max_retries - 1:
                time.sleep(delay)
                delay *= 2  # Exponential backoff
            else:
                print(f"Error in generate_requisitions_ajax: {str(e)}")
                return jsonify({'success': False, 'error': str(e)}), 500
        finally:
            if 'db' in locals():
                db.close()

    return jsonify({'success': False, 'error': 'Database locked after maximum retries'}), 500

@rfqs_bp.route('/get_rfq_line_currency/<int:line_id>')
def get_rfq_line_currency_route(line_id):
    logging.debug(f"Entered get_rfq_line_currency_route with line_id: {line_id}")
    try:
        logging.debug("Attempting to call get_rfq_line_currency")
        result = get_rfq_line_currency(line_id)
        logging.debug(f"Result from get_rfq_line_currency: {result}")
        return jsonify(result)
    except Exception as e:
        logging.error(f"Error in get_rfq_line_currency_route: {str(e)}")
        logging.error(f"Error type: {type(e).__name__}")
        logging.error(f"Error traceback: {traceback.format_exc()}")
        return jsonify({"success": False, "error": str(e)}), 500

