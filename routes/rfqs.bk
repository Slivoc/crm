def row_to_dict(row):
    return {key: row[key] for key in row.keys()}


@rfqs_bp.route('/rfqs', methods=['GET', 'POST'])
def rfqs():
    filter_customer = request.args.get('filter_customer', '').strip()
    filter_salesperson = request.args.get('filter_salesperson', '').strip()
    part_number = request.args.get('part_number', '').strip()
    base_part_number = create_base_part_number(part_number) if part_number else None

    rfqs = get_rfqs()

    if filter_customer:
        rfqs = [rfq for rfq in rfqs if rfq['customer_id'] == int(filter_customer)]

    if filter_salesperson:
        rfqs = [rfq for rfq in rfqs if rfq.get('salesperson_id') == int(filter_salesperson)]

    if base_part_number:
        rfqs = [rfq for rfq in rfqs if
                any(base_part_number in line['base_part_number'] for line in get_rfq_lines(rfq['id']))]

    customers = get_customers()
    salespeople = get_salespeople()

    for rfq in rfqs:
        customer = get_customer_by_id(rfq['customer_id'])
        salesperson_id = rfq.get('salesperson_id')
        salesperson = get_salesperson_by_id(salesperson_id) if salesperson_id else None
        rfq['customer_name'] = customer['name']
        rfq['salesperson_name'] = salesperson['name'] if salesperson else 'No salesperson'

    grouped_rfqs = {}
    for rfq in rfqs:
        if rfq['status'] == 'deleted':
            continue
        status = rfq['status']
        if status not in grouped_rfqs:
            grouped_rfqs[status] = []
        grouped_rfqs[status].append(rfq)

    today_date = date.today().isoformat()

    breadcrumbs = [
        ('Home', '/'),
        ('RFQs', url_for('rfqs.rfqs'))
    ]

    return render_template('rfqs.html', customers=customers, salespeople=salespeople, grouped_rfqs=grouped_rfqs,
                           today_date=today_date, breadcrumbs=breadcrumbs, part_number=part_number)


@rfqs_bp.route('/new', methods=['GET', 'POST'])
def create_rfq():
    logging.debug("Entered create_rfq route")
    if request.method == 'POST':
        logging.debug('Form data received: %s', request.form)
        db = get_db_connection()
        try:
            entered_date = request.form['entered_date']
            customer_id = request.form['customer_id']
            customer_ref = request.form['customer_ref']
            status = 'new'  # Default status for new RFQs
            currency = 'USD'  # Default currency, can be updated as needed
            salesperson_id = request.form.get('salesperson_id')  # Get the salesperson_id from the form

            logging.debug(f"Attempting to insert RFQ with data: {entered_date}, {customer_id}, {customer_ref}, {status}, {currency}, {salesperson_id}")

            # Insert the new RFQ
            db.execute(
                'INSERT INTO rfqs (entered_date, customer_id, customer_ref, status, currency, salesperson_id) VALUES (?, ?, ?, ?, ?, ?)',
                (entered_date, customer_id, customer_ref, status, currency, salesperson_id)
            )
            db.commit()

            # Get the ID of the newly created RFQ
            new_rfq_id = db.execute('SELECT last_insert_rowid()').fetchone()[0]

            flash('RFQ created successfully!', 'success')
            logging.info(f'RFQ created successfully with ID {new_rfq_id}')
        except sqlite3.Error as e:
            db.rollback()
            logging.error(f'SQLite error creating RFQ: {e}')
            flash(f'Database error creating RFQ: {e}', 'error')
            return redirect(url_for('rfqs.create_rfq'))
        except Exception as e:
            db.rollback()
            logging.error(f'Unexpected error creating RFQ: {e}')
            flash(f'Unexpected error creating RFQ: {e}', 'error')
            return redirect(url_for('rfqs.create_rfq'))
        finally:
            db.close()

        logging.debug(f"Redirecting to edit_rfq page for RFQ ID: {new_rfq_id}")
        # Redirect to the edit page of the newly created RFQ
        return redirect(url_for('rfqs.edit_rfq', rfq_id=new_rfq_id))

    logging.debug("Rendering create_rfq template")
    customers = get_customers()
    today_date = date.today().isoformat()  # Set the default date to today
    return render_template('rfqs.html', customers=customers, today_date=today_date)

@rfqs_bp.route('/open_rfq', methods=['POST'])
def open_rfq():
    rfq_id = request.form.get('rfq_id')
    if rfq_id:
        return redirect(url_for('rfqs.edit_rfq', rfq_id=rfq_id))
    else:
        flash('Please enter a valid RFQ ID', 'error')
        return redirect(url_for('rfqs.rfqs'))


@rfqs_bp.route('/<int:rfq_id>/edit', methods=['GET', 'POST'])
def edit_rfq(rfq_id):
    currencies = get_currencies()
    rfq = get_rfq_by_id(rfq_id)
    if not rfq:
        flash('RFQ not found!', 'error')
        return redirect(url_for('rfqs.rfqs'))

    if request.method == 'POST':
        try:
            entered_date = request.form['entered_date']
            customer_id = request.form['customer_id']
            contact_id = request.form['contact_id']
            customer_ref = request.form['customer_ref']
            status = request.form['status']
            currency = request.form['currency']
            salesperson_id = request.form.get('salesperson_id')

            update_rfq(rfq_id, entered_date, customer_id, contact_id, customer_ref, status, currency, salesperson_id)
            flash('RFQ updated successfully!', 'success')
        except Exception as e:
            flash(f'Error updating RFQ: {e}', 'error')
            return redirect(url_for('rfqs.edit_rfq', rfq_id=rfq_id))

        return redirect(url_for('rfqs.edit_rfq', rfq_id=rfq_id))

    clean_rfq_lines_base_part_numbers()

    rfq_lines = get_rfq_lines_with_offers(rfq_id)

    db = get_db_connection()
    cursor = db.cursor()

    for line in rfq_lines:
        if line['offer_id']:
            cursor.execute('''
                SELECT s.name as supplier_name
                FROM offers o
                JOIN suppliers s ON o.supplier_id = s.id
                WHERE o.id = ?
            ''', (line['offer_id'],))
            result = cursor.fetchone()
            if result:
                line['chosen_supplier_name'] = result['supplier_name']

        part_number_row = cursor.execute('SELECT part_number FROM part_numbers WHERE base_part_number = ?',
                                         (line['base_part_number'],)).fetchone()
        line['part_number'] = part_number_row['part_number'] if part_number_row else 'Unknown'

        chosen_supplier_row = cursor.execute('SELECT name FROM suppliers WHERE id = ?',
                                             (line['chosen_supplier'],)).fetchone()
        line['chosen_supplier_name'] = chosen_supplier_row['name'] if chosen_supplier_row else None

    max_line_number_row = cursor.execute('SELECT MAX(line_number) FROM rfq_lines WHERE rfq_id = ?',
                                         (rfq_id,)).fetchone()
    max_line_number_str = max_line_number_row[0] if max_line_number_row else None

    if max_line_number_str:
        try:
            max_line_number_float = float(max_line_number_str)
            max_line_number = math.ceil(max_line_number_float)
        except ValueError:
            logging.error(f"Unable to convert max line number: {max_line_number_str}")
            max_line_number = 0
    else:
        max_line_number = 0

    db.close()

    contacts = get_contacts_by_customer(rfq['customer_id'])
    customers = get_customers()
    salespeople = get_salespeople()
    files = get_files_by_rfq(rfq_id)
    all_part_numbers = get_all_part_numbers_with_manufacturers()
    all_manufacturers = get_all_manufacturers()
    past_requisitions = get_requisitions()
    suppliers = [dict(supplier) for supplier in get_suppliers()]
    statuses = get_statuses()

    for line in rfq_lines:
        base_part_number = line['base_part_number']
        line_past_requisitions = [req for req in past_requisitions if req['base_part_number'] == base_part_number]
        received_requisition_suppliers = set(req['supplier_id'] for req in line_past_requisitions)

        if isinstance(line, sqlite3.Row):
            line = dict(line)

        line['received_requisitions'] = [supplier for supplier in suppliers if
                                         supplier['id'] in received_requisition_suppliers]
        line['not_received_requisitions'] = [supplier for supplier in suppliers if
                                             supplier['id'] not in received_requisition_suppliers]
        line['past_suggested_suppliers'] = list(received_requisition_suppliers)

    currency_dict = {c['id']: c for c in currencies}

    for line in rfq_lines:
        if isinstance(line, sqlite3.Row):
            line = dict(line)

        if 'offers' in line and line['offers']:
            for offer in line['offers']:
                # Check for both 'currency_id' and 'id'
                currency_id = offer.get('currency_id') or offer.get('id')
                if currency_id and currency_id in currency_dict:
                    offer['currency_symbol'] = currency_dict[currency_id]['symbol']
                else:
                    offer['currency_symbol'] = ''

    return render_template(
        'rfq_edit.html',
        rfq=rfq,
        rfq_lines=rfq_lines,
        contacts=contacts,
        customers=customers,
        salespeople=salespeople,
        files=files,
        all_part_numbers=all_part_numbers,
        all_manufacturers=all_manufacturers,
        max_line_number=max_line_number,
        suppliers=suppliers,
        get_currency_symbol=get_currency_symbol,
        currencies=currencies,
        statuses=statuses
    )

# Define a function to get all statuses
def get_statuses():
    db = get_db_connection()
    statuses = db.execute('SELECT id, status FROM statuses').fetchall()
    db.close()
    return statuses


@rfqs_bp.route('/<int:rfq_id>/add_rfq_line', methods=['POST'])
def add_rfq_line(rfq_id):
    line_number = request.form.get('line_number')
    part_number = request.form.get('part_number')
    quantity = request.form.get('quantity')
    manufacturer_id = request.form.get('manufacturer_id')
    customer_part_number = request.form.get('customer_part_number')

    base_part_number = create_base_part_number(part_number)

    conn = get_db_connection()
    cursor = conn.cursor()

    # Check if part exists
    part = cursor.execute('SELECT base_part_number FROM part_numbers WHERE base_part_number = ?',
                          (base_part_number,)).fetchone()

    # If part does not exist, insert it
    if not part:
        cursor.execute('INSERT INTO part_numbers (part_number, base_part_number) VALUES (?, ?)',
                       (part_number, base_part_number))

    # Query past requisitions to determine suggested suppliers
    cursor.execute('''
        SELECT DISTINCT supplier_id FROM requisitions
        WHERE base_part_number = ?
    ''', (base_part_number,))
    suggested_suppliers = [str(row['supplier_id']) for row in cursor.fetchall()]

    # Convert the list of supplier IDs to a comma-separated string
    suggested_suppliers_str = ','.join(suggested_suppliers)

    # Insert the RFQ line with the suggested suppliers
    cursor.execute('''
        INSERT INTO rfq_lines (rfq_id, line_number, base_part_number, quantity, manufacturer_id, suggested_suppliers)
        VALUES (?, ?, ?, ?, ?, ?)
    ''', (rfq_id, line_number, base_part_number, quantity, manufacturer_id, suggested_suppliers_str))

    # Check if the part-manufacturer association exists
    if manufacturer_id:
        association = cursor.execute('''
            SELECT * FROM part_manufacturers
            WHERE base_part_number = ? AND manufacturer_id = ?
        ''', (base_part_number, manufacturer_id)).fetchone()

        # If not, insert the association
        if not association:
            cursor.execute('''
                INSERT INTO part_manufacturers (base_part_number, manufacturer_id)
                VALUES (?, ?)
            ''', (base_part_number, manufacturer_id))

    # Insert customer part number if provided
    if customer_part_number:
        customer_id = get_customer_id_by_rfq(rfq_id)
        cursor.execute('''
            INSERT INTO customer_part_numbers (base_part_number, customer_part_number, customer_id)
            VALUES (?, ?, ?)
        ''', (base_part_number, customer_part_number, customer_id))

    conn.commit()
    conn.close()

    flash('RFQ line added successfully with suggested suppliers!', 'success')
    return redirect(url_for('rfqs.edit_rfq', rfq_id=rfq_id))


@rfqs_bp.route('/<int:rfq_id>/set_default_margin', methods=['POST'])
def set_default_margin(rfq_id):
    default_margin = float(request.form['default_margin'])
