@rfqs_bp.route('/update_base_cost', methods=['POST'])
def update_base_cost():
    data = request.json
    line_id = data.get('line_id')
    base_cost = data.get('base_cost')
    cost_currency = data.get('cost_currency')
    exchange_rate = data.get('exchange_rate_to_eur')  # Retrieve the exchange rate from the request

    # Ensure that all fields are valid
    if not line_id or base_cost is None or not isinstance(cost_currency, int) or exchange_rate is None:
        return jsonify(success=False, error="Invalid input data"), 400

    db = get_db_connection()
    cursor = db.cursor()

    try:
        # Calculate base_cost using the provided exchange rate (no need to fetch again)
        base_cost = base_cost / exchange_rate
        logging.debug(f"Calculated base cost: {base_cost}")

        # Update base cost with correct currency ID
        update_rfq_line_base_cost(cursor, line_id, base_cost, cost_currency)
        db.commit()
        return jsonify(success=True, message="Base cost updated successfully")
    except Exception as e:
        db.rollback()
        logging.error(f"Error updating base cost for line_id {line_id}: {e}")
        return jsonify(success=False, error=str(e)), 500
    finally:
        db.close()


